#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd -- "$script_dir/.." && pwd)"
codex_home="${1:-${CODEX_HOME:-$HOME/.codex}}"

require_text() {
  local file="$1"
  local text="$2"

  if ! grep -Fq -- "$text" "$file"; then
    printf 'missing required text in %s: %s\n' "$file" "$text" >&2
    exit 1
  fi
}

require_file() {
  local file="$1"

  if [ ! -f "$file" ]; then
    printf 'missing required file: %s\n' "$file" >&2
    exit 1
  fi
}

require_text "$repo_dir/AGENTS.md" "validates the proposed approach against repo reality"
require_text "$repo_dir/AGENTS.md" "reusable local patterns"
require_text "$repo_dir/AGENTS.md" "[DONE]"
require_text "$repo_dir/AGENTS.md" "next action needed from the coordinator"
require_text "$repo_dir/AGENTS.md" "keeps tending the work"

require_text "$repo_dir/global/AGENTS.md" "validates the proposed approach against repo reality"
require_text "$repo_dir/global/AGENTS.md" "reusable local patterns"
require_text "$repo_dir/global/AGENTS.md" "[DONE]"
require_text "$repo_dir/global/AGENTS.md" "next action needed from the coordinator"
require_text "$repo_dir/global/AGENTS.md" "keeps tending the work"
require_text "$repo_dir/AGENTS.md" "skills/frontend-skills/<skill>/SKILL.md"
require_text "$repo_dir/AGENTS.md" "design-taste-frontend"
require_text "$repo_dir/AGENTS.md" "stitch-design-taste"
require_text "$repo_dir/global/AGENTS.md" "~/.codex/skills/frontend-skills/<skill>/SKILL.md"
require_text "$repo_dir/global/AGENTS.md" "design-taste-frontend"
require_text "$repo_dir/global/AGENTS.md" "stitch-design-taste"

require_text "$repo_dir/templates/PROJECT_AGENTS.md" "validate the approach against real project"
require_text "$repo_dir/templates/PROJECT_AGENTS.md" "files and define the intended verification"
require_text "$repo_dir/templates/PROJECT_AGENTS.md" "next coordinator action"
require_text "$repo_dir/templates/PROJECT_WORKLOG.md" "structured handoffs"
require_text "$repo_dir/templates/PROJECT_WORKLOG.md" "next coordinator action"

python3 - "$repo_dir" "$codex_home" <<'PY'
import sys
import tomllib
from pathlib import Path

repo = Path(sys.argv[1])
codex_home = Path(sys.argv[2])

source_agents = repo / "global" / "agents"
required_agents = [
    "pm",
    "architect",
    "backend",
    "frontend",
    "qa",
    "review",
    "stitch-frontend",
]
readonly_agents = {"pm", "architect", "qa", "review"}

for name in required_agents:
    path = source_agents / f"{name}.toml"
    data = tomllib.loads(path.read_text())
    for key in ("name", "description"):
        if not data.get(key):
            raise SystemExit(f"{path} is missing {key}")
    if name in readonly_agents and data.get("sandbox_mode") != "read-only":
        raise SystemExit(f"{path} must set sandbox_mode = read-only")

config_path = codex_home / "config.toml"
if config_path.exists():
    config = tomllib.loads(config_path.read_text())
    if config.get("agents", {}).get("max_depth") != 1:
        raise SystemExit(f"{config_path} must set agents.max_depth = 1")
    for name in required_agents:
        entry = config.get("agents", {}).get(name)
        if not isinstance(entry, dict):
            raise SystemExit(f"{config_path} is missing agents.{name}")
        if entry.get("config_file") != f"agents/{name}.toml":
            raise SystemExit(f"{config_path} has wrong config_file for {name}")
PY

if [ -d "$codex_home" ]; then
  require_file "$codex_home/AGENTS.md"
  diff -q "$repo_dir/global/AGENTS.md" "$codex_home/AGENTS.md" >/dev/null

  for agent in pm architect backend frontend qa review stitch-frontend; do
    require_file "$codex_home/agents/$agent.toml"
    diff -q "$repo_dir/global/agents/$agent.toml" "$codex_home/agents/$agent.toml" >/dev/null
  done

  require_file "$codex_home/templates/PROJECT_AGENTS.md"
  require_file "$codex_home/templates/PROJECT_WORKLOG.md"
  diff -q "$repo_dir/templates/PROJECT_AGENTS.md" "$codex_home/templates/PROJECT_AGENTS.md" >/dev/null
  diff -q "$repo_dir/templates/PROJECT_WORKLOG.md" "$codex_home/templates/PROJECT_WORKLOG.md" >/dev/null

  codex_skill_count="$(find "$codex_home/skills/codex-team-skills" -maxdepth 2 -name SKILL.md | wc -l | tr -d ' ')"
  frontend_skill_count="$(find "$codex_home/skills/frontend-skills" -maxdepth 2 -name SKILL.md | wc -l | tr -d ' ')"
  [ "$codex_skill_count" = "13" ] || {
    printf 'expected 13 codex-team skills in %s, found %s\n' "$codex_home" "$codex_skill_count" >&2
    exit 1
  }
  [ "$frontend_skill_count" = "12" ] || {
    printf 'expected 12 frontend skills in %s, found %s\n' "$codex_home" "$frontend_skill_count" >&2
    exit 1
  }
fi

echo "agent workflow checks passed"
